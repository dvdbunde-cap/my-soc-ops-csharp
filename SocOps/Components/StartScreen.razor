<div class="flex flex-col items-center justify-center min-h-full p-6 bg-gradient-primary relative overflow-hidden">

    <!-- Glass Card Container -->
    <div class="glass rounded-xl p-8 max-w-2xl w-full mx-auto animate-fade-in relative z-10">
        <!-- Main Title -->
        <div class="text-center mb-8">
            <h1 class="heading-xl mb-3">SOC OPS</h1>
            <div class="text-gradient text-lg font-medium tracking-wide">SOCIAL BINGO</div>
        </div>

        <!-- How to Play - Glass Blocks -->
        <div class="mb-8 text-left">
            <div class="glass rounded-md p-3 mb-4 border-0">
                <h2 class="text-dark text-sm font-semibold tracking-wide uppercase">How to Play</h2>
            </div>
            <div class="space-y-3">
                <div class="glass rounded-md p-4 flex items-center gap-3">
                    <span class="text-gradient font-bold text-lg">01</span>
                    <span class="text-dark">Find people who match the questions</span>
                </div>
                <div class="glass rounded-md p-4 flex items-center gap-3">
                    <span class="text-gradient font-bold text-lg">02</span>
                    <span class="text-dark">Tap a square when you find a match</span>
                </div>
                <div class="glass rounded-md p-4 flex items-center gap-3">
                    <span class="text-gradient font-bold text-lg">03</span>
                    <span class="text-dark">Get 5 in a row to win!</span>
                </div>
            </div>
        </div>

        <!-- Mode Selection Buttons -->
        <div class="space-y-4">
            <button
                @onclick="() => OnStart.InvokeAsync(GameMode.Bingo)"
                class="w-full bg-gradient-primary text-white font-semibold py-4 px-8 text-lg rounded-lg hover-scale transition-all relative overflow-hidden border-0">
                <span class="relative z-10">🎯 BINGO</span>
            </button>

            <button
                @onclick="() => OnStart.InvokeAsync(GameMode.ScavengerHunt)"
                class="w-full bg-gradient-success text-white font-semibold py-4 px-8 text-lg rounded-lg hover-scale transition-all relative overflow-hidden border-0">
                <span class="relative z-10">🔍 SCAVENGER HUNT</span>
            </button>

            <button
                @onclick="() => OnStart.InvokeAsync(GameMode.CardDeckShuffle)"
                class="w-full bg-gradient-sunset text-white font-semibold py-4 px-8 text-lg rounded-lg hover-scale transition-all relative overflow-hidden border-0">
                <span class="relative z-10">🃏 CARD DECK SHUFFLE</span>
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<GameMode> OnStart { get; set; }
}
