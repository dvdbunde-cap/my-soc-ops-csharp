@using SocOps.Models

<div class="flex flex-col min-h-full bg-white">
    <!-- Header - Industrial Black Bar -->
    <header class="flex items-center justify-between p-3 bg-black text-white border-b-6 border-red">
        <button
            @onclick="OnReset"
            class="text-white text-sm px-3 py-2 uppercase tracking-wide hover:translate-x-1 transition-all"
            style="font-family: var(--font-heading);">
            ← BACK
        </button>
        <h1 class="heading-md text-yellow tracking-wider">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions - Bold & Uppercase -->
    <p class="text-center text-black text-sm py-3 px-4 uppercase tracking-wide font-bold bg-yellow border-b-3 border-black">
        Tap a square when you find someone who matches it
    </p>

    <!-- BINGO Alert - Diagonal Stripes -->
    @if (HasBingo)
    {
        <div class="diagonal-stripes-red text-white text-center py-3 font-bold text-lg uppercase tracking-wider animate-sweep border-b-6 border-black">
            <span class="relative z-10">★ BINGO! YOU GOT A LINE! ★</span>
        </div>
    }

    <!-- Board Container -->
    <div class="flex-1 flex items-center justify-center p-4">
        <div class="border-6 border-black p-2 bg-white" style="box-shadow: 8px 8px 0 var(--color-black);">
            <BingoBoard
                Board="@Board"
                WinningSquareIds="@WinningSquareIds"
                OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
