@using SocOps.Models

<div class="flex flex-col min-h-full bg-gradient-warm">
    <!-- Glass Header -->
    <header class="glass flex items-center justify-between p-3 rounded-none">
        <button
            @onclick="OnReset"
            class="text-white text-sm px-4 py-2 rounded-md hover-scale transition-all font-medium">
            ← BACK
        </button>
        <h1 class="heading-md text-white tracking-wide">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions - Glass Pill -->
    <div class="flex justify-center py-3 px-4">
        <p class="glass text-dark text-sm py-2 px-6 rounded-full text-center font-light">
            Tap a square when you find someone who matches it
        </p>
    </div>

    <!-- BINGO Alert - Glass Card with Glow -->
    @if (HasBingo)
    {
        <div class="glass rounded-lg mx-4 py-4 text-center animate-glow border-0">
            <span class="text-gradient font-bold text-lg">★ BINGO! YOU GOT A LINE! ★</span>
        </div>
    }

    <!-- Board Container - Glass -->
    <div class="flex-1 flex items-center justify-center p-4">
        <div class="glass rounded-xl p-3">
            <BingoBoard
                Board="@Board"
                WinningSquareIds="@WinningSquareIds"
                OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
