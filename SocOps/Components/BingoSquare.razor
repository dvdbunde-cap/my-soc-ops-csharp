@using SocOps.Models;

<button @onclick="OnClick"
        disabled="@Square.IsFreeSpace"
        class="@GetCssClasses()"
        aria-pressed="@Square.IsMarked"
        aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto font-medium">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-2 right-2 text-white text-lg font-bold">✕</span>
    }
    @if (Square.IsFreeSpace)
    {
        <span class="absolute inset-0 flex items-center justify-center opacity-30">
            <div class="w-6 h-6 rounded-full border-2 border-current"></div>
        </span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-3 text-center select-none min-h-[60px] text-xs leading-tight rounded-lg font-medium transition-all hover-scale";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-gradient-success text-white animate-glow"
                : "bg-gradient-warm text-white shadow-lg"
            : "glass text-dark border-0";

        var freeSpaceClasses = Square.IsFreeSpace ? "cursor-default opacity-90" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
