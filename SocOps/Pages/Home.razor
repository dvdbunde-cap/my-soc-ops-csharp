@page "/"
@using SocOps.Models
@using SocOps.Services
@inject BingoGameService GameService
@inject CardDeckService CardDeck
@implements IDisposable

<PageTitle>Soc Ops - Social Bingo</PageTitle>

@if (GameService.CurrentGameState == GameState.Start)
{
    <StartScreen OnStart="@HandleStart" />
}
else if (GameService.CurrentGameMode == GameMode.Bingo)
{
    <GameScreen
        Board="@GameService.Board"
        WinningSquareIds="@GameService.WinningSquareIds"
        HasBingo="@(GameService.CurrentGameState == GameState.Bingo)"
        OnSquareClick="@GameService.HandleSquareClick"
        OnReset="@GameService.ResetGame" />

    @if (GameService.ShowBingoModal)
    {
        <BingoModal OnDismiss="@GameService.DismissModal" />
    }
}
else if (GameService.CurrentGameMode == GameMode.ScavengerHunt)
{
    <ScavengerHuntScreen
        Items="@GameService.ScavengerHuntList"
        Progress="@GameService.ScavengerHuntProgress"
        IsComplete="@GameService.IsScavengerHuntComplete"
        OnToggle="@GameService.ToggleScavengerHuntItem"
        OnReset="@GameService.ResetGame" />
}
else if (GameService.CurrentGameMode == GameMode.CardDeckShuffle)
{
    <CardDeckScreen
        CurrentCard="@CardDeck.CurrentCard"
        CardsDrawn="@CardDeck.CardsDrawn"
        TotalCards="@CardDeck.TotalCards"
        HasMoreCards="@CardDeck.HasMoreCards"
        OnDrawCard="@(() => CardDeck.DrawCard())"
        OnCardClick="@(() => CardDeck.MarkCurrentCard())"
        OnReset="@HandleReset"
        OnResetDeck="@(() => CardDeck.ResetDeck())" />
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await GameService.InitializeAsync();
        GameService.OnStateChanged += StateHasChanged;
        CardDeck.OnStateChanged += StateHasChanged;
    }

    private void HandleStart(GameMode mode)
    {
        GameService.StartGame(mode);
        if (mode == GameMode.CardDeckShuffle)
        {
            CardDeck.InitializeDeck();
        }
    }

    private void HandleReset()
    {
        GameService.ResetGame();
        CardDeck.ResetDeck();
    }

    public void Dispose()
    {
        GameService.OnStateChanged -= StateHasChanged;
        CardDeck.OnStateChanged -= StateHasChanged;
    }
}
